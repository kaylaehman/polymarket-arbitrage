# Copy to .env (gitignored) and fill in. Empty values are fine — the bot stays
# in dry_run and reads config.yaml. Only set what you actually use.

# --- Kalshi (US users) ---
# From Kalshi -> Settings -> API Keys. Put the .pem in ./secrets/ and reference it.
KALSHI_API_KEY_ID=
KALSHI_PRIVATE_KEY=/app/secrets/kalshi.pem

# --- Polymarket (only if you can trade it) ---
# Polygon wallet private key. signature_type stays in config.yaml.
POLYMARKET_PRIVATE_KEY=
# Only for proxy wallets (signature_type 1/2): the USDC-holding address.
POLYMARKET_FUNDER=
# Optional — auto-derived from the key if blank.
POLYMARKET_API_KEY=
POLYMARKET_API_SECRET=
POLYMARKET_PASSPHRASE=

# --- Polymarket.US (Ed25519 REST API) ---
# Disabled by default. Set mode.polymarket_us_enabled: true in config.yaml to use.
# POLYMARKET_US_KEY_ID=
# POLYMARKET_US_SECRET_KEY=

# --- Alerts (Discord / Telegram push notifications) ---
# Set alerts.enabled: true in config.yaml to activate.
# ALERT_DISCORD_WEBHOOK=https://discord.com/api/webhooks/YOUR_WEBHOOK_ID/YOUR_WEBHOOK_TOKEN
# ALERT_TELEGRAM_BOT_TOKEN=123456:ABCDefghIJKlmnOP
# ALERT_TELEGRAM_CHAT_ID=-100123456789

# Macro nowcast gate (GDPNow via FRED). Free key: https://fredaccount.stlouisfed.org/apikeys
FRED_API_KEY=
